# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you use pyenv
#   Keep it commented out if you want to share it
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git
#   However, if you're running an app, you might want to share it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in git
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in git
#pdm.lock

